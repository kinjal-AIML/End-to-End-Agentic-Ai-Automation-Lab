# Import necessary libraries
import pandas as pd
import matplotlib.pyplot as plt

# Read the CSV file from the current directory
df = pd.read_csv('iris.csv')

# Plot a bar chart of flower types by sepal length
plt.figure(figsize=(10,6))
for i, species in enumerate(df['species'].unique()):
    plt.bar(species, df[df['species'] == species]['sepal length (cm)'].mean(), label=species)

# Add title and labels
plt.title('Mean Sepal Length by Flower Type')
plt.xlabel('Flower Type')
plt.ylabel('Sepal Length (cm)')
plt.legend()

# Display the plot
print(plt.show())

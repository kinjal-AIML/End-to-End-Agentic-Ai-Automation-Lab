import sys
import subprocess

try:
    import pandas as pd
except ImportError:
    # Install the required libraries
    subprocess.check_call([sys.executable, "-m", "pip", "install", 'pandas'])
    import pandas as pd

# Read the csv file into a DataFrame
df = pd.read_csv('data.csv')
# Get the column names
column_names = df.columns.tolist()
print(column_names)

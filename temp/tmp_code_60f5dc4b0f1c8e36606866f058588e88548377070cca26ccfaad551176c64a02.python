import pandas as pd

def get_column_names(file_name):
    try:
        # Read the CSV file into a DataFrame
        df = pd.read_csv(file_name)
        
        # Get the column names
        column_names = df.columns.tolist()
        
        print(f"Data File: {file_name}")
        print("Column Names:")
        for i, col in enumerate(column_names):
            print(f"{i+1}. {col}")
        
        return column_names
    
    except Exception as e:
        print(f"An error occurred: {e}")

# Specify the filename and path (in this case, it's in the current working directory)
file_name = "data.csv"

get_column_names(file_name)
